{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seal.local/schemas/debt.schema.json",
  "title": "SEAL DEBT v2",
  "type": "object",
  "required": ["schema_version", "source_refs", "records"],
  "properties": {
    "schema_version": { "$ref": "#/$defs/semver" },
    "source_refs": { "$ref": "#/$defs/sourceRefs" },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "subject", "severity", "source_refs", "blocks", "closure_method", "status", "created_by"],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "type": {
            "type": "string",
            "enum": [
              "unknown_file",
              "orphan_component",
              "missing_owner",
              "missing_requirement",
              "missing_test",
              "missing_evidence",
              "stale_evidence",
              "broken_trace",
              "unapproved_inference",
              "risky_dependency",
              "hidden_service",
              "cost_unknown",
              "schema_without_migration",
              "interface_without_contract",
              "plan_code_divergence"
            ]
          },
          "subject": { "type": "string", "minLength": 1 },
          "severity": { "type": "string", "enum": ["info", "warning", "blocker"] },
          "source_refs": { "$ref": "#/$defs/sourceRefs" },
          "blocks": { "type": "array", "items": { "$ref": "#/$defs/id" } },
          "closure_method": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["open", "accepted", "closed"] },
          "created_by": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "file_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "component_refs": { "type": "array", "items": { "$ref": "#/$defs/id" } },
          "gap_refs": { "type": "array", "items": { "$ref": "#/$defs/id" } },
          "test_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "dependency_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "authority_state": { "$ref": "#/$defs/authorityState" },
          "approval_state": { "$ref": "#/$defs/approvalState" },
          "confidence": { "$ref": "#/$defs/confidence" },
          "plain_language": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "semver": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "id": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9._:\\-]*$" },
    "sourceRefs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/id" } },
    "authorityState": { "type": "string", "enum": ["human_approved", "repo_observed", "externally_sourced", "execution_evidence", "mathematically_proven", "inferred", "unknown"] },
    "approvalState": { "type": "string", "enum": ["approved", "pending", "rejected", "not_required"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": true
}
