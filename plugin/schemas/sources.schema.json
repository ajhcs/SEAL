{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seal.local/schemas/sources.schema.json",
  "title": "SEAL SOURCES v2",
  "type": "object",
  "required": ["schema_version", "sources"],
  "properties": {
    "schema_version": { "$ref": "#/$defs/semver" },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/sourceRecord" }
    }
  },
  "$defs": {
    "semver": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "id": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9._:\\-]*$" },
    "authorityKind": {
      "type": "string",
      "enum": [
        "human_input",
        "repo_observation",
        "command_execution",
        "external_source_snapshot",
        "mathematical_or_code_proof",
        "inference",
        "unknown"
      ]
    },
    "authorityState": {
      "type": "string",
      "enum": [
        "human_approved",
        "repo_observed",
        "externally_sourced",
        "execution_evidence",
        "mathematically_proven",
        "inferred",
        "unknown"
      ]
    },
    "approvalState": { "type": "string", "enum": ["approved", "pending", "rejected", "not_required"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "sourceRecord": {
      "type": "object",
      "required": ["id", "kind", "description", "authority_state", "approval_state", "confidence"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": { "$ref": "#/$defs/authorityKind" },
        "description": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "captured_at": { "type": "string", "minLength": 1 },
        "authority_state": { "$ref": "#/$defs/authorityState" },
        "approval_state": { "$ref": "#/$defs/approvalState" },
        "confidence": { "$ref": "#/$defs/confidence" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
