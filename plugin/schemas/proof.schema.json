{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seal.local/schemas/proof.schema.json",
  "title": "SEAL Proof",
  "type": "object",
  "required": ["schema_version", "claims", "gaps"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "statement", "source_refs", "evidence_refs", "gap_refs"],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "type": { "$ref": "#/$defs/claimType" },
          "statement": { "type": "string", "minLength": 1 },
          "source_refs": { "$ref": "#/$defs/sourceRefs" },
          "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/id" } },
          "gap_refs": { "type": "array", "items": { "$ref": "#/$defs/id" } },
          "authority_state": { "$ref": "#/$defs/authorityState" },
          "approval_state": { "$ref": "#/$defs/approvalState" },
          "confidence": { "$ref": "#/$defs/confidence" }
        },
        "anyOf": [
          { "properties": { "evidence_refs": { "type": "array", "minItems": 1 } } },
          { "properties": { "gap_refs": { "type": "array", "minItems": 1 } } }
        ],
        "additionalProperties": true
      }
    },
    "gaps": { "type": "array", "items": { "$ref": "#/$defs/gap" } }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9._:-]*$" },
    "claimType": {
      "type": "string",
      "enum": ["functional", "safety", "reliability", "security", "performance", "usability", "launch", "operational"]
    },
    "sourceRefs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/id" } },
    "gap": {
      "type": "object",
      "required": ["id", "summary", "reason", "source_refs", "status"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "summary": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "source_refs": { "$ref": "#/$defs/sourceRefs" },
        "authority_state": { "$ref": "#/$defs/authorityState" },
        "approval_state": { "$ref": "#/$defs/approvalState" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "status": { "type": "string", "enum": ["open", "accepted", "closed"] }
      },
      "additionalProperties": true
    },
    "authorityState": { "type": "string", "enum": ["human_approved", "repo_observed", "externally_sourced", "execution_evidence", "mathematically_proven", "inferred", "unknown"] },
    "approvalState": { "type": "string", "enum": ["approved", "pending", "rejected", "not_required"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": false
}
