{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seal.local/schemas/proof.schema.json",
  "title": "SEAL PROVE v2",
  "type": "object",
  "required": ["schema_version", "claims", "evidence", "gaps"],
  "properties": {
    "schema_version": { "$ref": "#/$defs/semver" },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "subject",
          "statement",
          "type",
          "status",
          "source_refs",
          "evidence_refs",
          "gap_refs",
          "counterevidence_refs",
          "limitations",
          "freshness",
          "confidence"
        ],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "subject": { "type": "string", "minLength": 1 },
          "statement": { "type": "string", "minLength": 1 },
          "type": { "$ref": "#/$defs/claimType" },
          "status": { "type": "string", "enum": ["proven", "gapped", "rejected", "stale", "conflicted"] },
          "source_refs": { "$ref": "#/$defs/sourceRefs" },
          "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/id" } },
          "gap_refs": { "type": "array", "items": { "$ref": "#/$defs/id" } },
          "counterevidence_refs": { "type": "array", "items": { "$ref": "#/$defs/id" } },
          "limitations": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "freshness": {
            "type": "object",
            "required": ["status", "checked_at"],
            "properties": {
              "status": { "type": "string", "enum": ["current", "stale", "unknown"] },
              "checked_at": { "type": "string", "minLength": 1 },
              "basis": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": true
          },
          "confidence": { "$ref": "#/$defs/confidence" },
          "authority_state": { "$ref": "#/$defs/authorityState" },
          "approval_state": { "$ref": "#/$defs/approvalState" }
        },
        "additionalProperties": true
      }
    },
    "evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidenceRecord" }
    },
    "gaps": {
      "type": "array",
      "items": { "$ref": "#/$defs/gapRecord" }
    }
  },
  "$defs": {
    "semver": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "id": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9._:\\-]*$" },
    "sourceRefs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/id" } },
    "claimType": {
      "type": "string",
      "enum": ["functional", "safety", "reliability", "security", "performance", "usability", "launch", "operational", "data", "cost", "accessibility", "architecture"]
    },
    "evidenceType": {
      "type": "string",
      "enum": [
        "unit_test",
        "integration_test",
        "e2e_test",
        "contract_test",
        "schema_validation",
        "migration_dry_run",
        "typecheck",
        "lint",
        "static_analysis",
        "security_scan",
        "accessibility_check",
        "visual_review",
        "screenshot",
        "browser_recording",
        "performance_measurement",
        "cost_calculation",
        "load_test",
        "fault_injection",
        "property_based_test",
        "model_check",
        "mathematical_analysis",
        "telemetry",
        "canary_result",
        "human_approval",
        "external_source_snapshot",
        "repo_observation",
        "command_output",
        "static_inspection",
        "external_reference",
        "gap_record",
        "test_result"
      ]
    },
    "authorityState": { "type": "string", "enum": ["human_approved", "repo_observed", "externally_sourced", "execution_evidence", "mathematically_proven", "inferred", "unknown"] },
    "approvalState": { "type": "string", "enum": ["approved", "pending", "rejected", "not_required"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "severity": { "type": "string", "enum": ["info", "warning", "blocker"] },
    "evidenceRecord": {
      "type": "object",
      "required": [
        "id",
        "type",
        "method",
        "source",
        "result",
        "supports",
        "refutes",
        "captured_at",
        "limitations"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "type": { "$ref": "#/$defs/evidenceType" },
        "method": { "type": "string", "minLength": 1 },
        "source": {
          "type": "object",
          "required": ["kind"],
          "properties": {
            "kind": { "type": "string", "minLength": 1 },
            "summary": { "type": "string", "minLength": 1 },
            "command": { "type": "string", "minLength": 1 },
            "source_ref": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": true
        },
        "result": { "type": "string", "minLength": 1 },
        "supports": { "type": "array", "items": { "$ref": "#/$defs/id" } },
        "refutes": { "type": "array", "items": { "$ref": "#/$defs/id" } },
        "captured_at": { "type": "string", "minLength": 1 },
        "artifact_path": { "type": "string", "minLength": 1 },
        "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "limitations": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "source_refs": { "type": "array", "items": { "$ref": "#/$defs/id" } },
        "authority_state": { "$ref": "#/$defs/authorityState" },
        "approval_state": { "$ref": "#/$defs/approvalState" },
        "confidence": { "$ref": "#/$defs/confidence" }
      },
      "additionalProperties": true
    },
    "gapRecord": {
      "type": "object",
      "required": ["id", "missing", "closure_method", "blocks", "severity", "status", "source_refs"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "missing": { "type": "string", "minLength": 1 },
        "closure_method": { "type": "string", "minLength": 1 },
        "blocks": { "type": "array", "items": { "$ref": "#/$defs/id" } },
        "severity": { "$ref": "#/$defs/severity" },
        "status": { "type": "string", "enum": ["open", "accepted", "closed"] },
        "source_refs": { "$ref": "#/$defs/sourceRefs" },
        "authority_state": { "$ref": "#/$defs/authorityState" },
        "approval_state": { "$ref": "#/$defs/approvalState" },
        "confidence": { "$ref": "#/$defs/confidence" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
