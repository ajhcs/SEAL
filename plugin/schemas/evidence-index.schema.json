{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seal.local/schemas/evidence-index.schema.json",
  "title": "SEAL Evidence Index",
  "type": "object",
  "required": ["schema_version", "evidence"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
          "required": ["id", "type", "claim_ids", "status", "captured_at", "source", "limitations"],
          "properties": {
            "id": { "$ref": "#/$defs/id" },
            "type": { "type": "string", "enum": ["command_output", "static_inspection", "external_reference", "human_approval", "gap_record", "test_result"] },
            "claim_ids": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/id" } },
            "status": { "type": "string", "enum": ["passed", "failed", "incomplete", "stale"] },
            "captured_at": { "type": "string" },
            "source": { "$ref": "#/$defs/evidenceSource" },
            "artifact_path": { "type": "string", "minLength": 1 },
            "artifact_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "hash_algorithm": { "type": "string", "enum": ["sha256"] },
            "redaction": { "type": "string", "enum": ["none", "summary_only", "not_applicable"] },
            "source_refs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/id" } },
            "authority_state": { "$ref": "#/$defs/authorityState" },
            "approval_state": { "$ref": "#/$defs/approvalState" },
          "confidence": { "$ref": "#/$defs/confidence" },
          "limitations": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9._:-]*$" },
    "evidenceSource": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "enum": ["command", "static_inspection", "external_source", "human_review", "gap_record"] },
        "command": { "type": "string", "minLength": 1 },
        "source_ref": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "authorityState": { "type": "string", "enum": ["human_approved", "repo_observed", "externally_sourced", "execution_evidence", "mathematically_proven", "inferred", "unknown"] },
    "approvalState": { "type": "string", "enum": ["approved", "pending", "rejected", "not_required"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": false
}
