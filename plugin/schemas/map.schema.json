{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seal.local/schemas/map.schema.json",
  "title": "SEAL MAP v2",
  "type": "object",
  "required": [
    "schema_version",
    "purpose",
    "boundary",
    "observed",
    "approved",
    "drift",
    "components",
    "files",
    "dependencies",
    "services",
    "interfaces",
    "data_stores",
    "tests",
    "unknowns",
    "sources"
  ],
  "properties": {
    "schema_version": { "$ref": "#/$defs/semver" },
    "purpose": { "$ref": "#/$defs/sourcedText" },
    "boundary": {
      "type": "object",
      "required": ["root", "included", "excluded", "source_refs"],
      "properties": {
        "root": { "type": "string", "minLength": 1 },
        "included": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "excluded": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "source_refs": { "$ref": "#/$defs/sourceRefs" },
        "authority_state": { "$ref": "#/$defs/authorityState" },
        "approval_state": { "$ref": "#/$defs/approvalState" },
        "confidence": { "$ref": "#/$defs/confidence" }
      },
      "additionalProperties": true
    },
    "observed": {
      "type": "object",
      "required": ["components", "files", "dependencies", "services", "interfaces", "data_stores", "tests", "source_refs"],
      "properties": {
        "components": { "type": "array", "items": { "$ref": "#/$defs/id" } },
        "files": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "dependencies": { "type": "array", "items": { "$ref": "#/$defs/idOrPath" } },
        "services": { "type": "array", "items": { "$ref": "#/$defs/idOrPath" } },
        "interfaces": { "type": "array", "items": { "$ref": "#/$defs/id" } },
        "data_stores": { "type": "array", "items": { "$ref": "#/$defs/id" } },
        "tests": { "type": "array", "items": { "$ref": "#/$defs/idOrPath" } },
        "source_refs": { "$ref": "#/$defs/sourceRefs" }
      },
      "additionalProperties": true
    },
    "approved": {
      "type": "object",
      "required": ["components", "boundaries", "interfaces", "source_refs", "status"],
      "properties": {
        "components": { "type": "array", "items": { "$ref": "#/$defs/id" } },
        "boundaries": { "type": "array", "items": { "$ref": "#/$defs/idOrPath" } },
        "interfaces": { "type": "array", "items": { "$ref": "#/$defs/id" } },
        "source_refs": { "type": "array", "items": { "$ref": "#/$defs/id" } },
        "status": { "type": "string", "enum": ["none", "draft", "proposed", "approved", "superseded", "rejected"] },
        "authority_state": { "$ref": "#/$defs/authorityState" },
        "approval_state": { "$ref": "#/$defs/approvalState" },
        "confidence": { "$ref": "#/$defs/confidence" }
      },
      "additionalProperties": true
    },
    "drift": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "issue", "source_refs"],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "observed_component": { "$ref": "#/$defs/id" },
          "approved_component": { "type": ["string", "null"] },
          "issue": { "type": "string", "minLength": 1 },
          "severity": { "$ref": "#/$defs/severity" },
          "source_refs": { "$ref": "#/$defs/sourceRefs" },
          "authority_state": { "$ref": "#/$defs/authorityState" },
          "approval_state": { "$ref": "#/$defs/approvalState" },
          "confidence": { "$ref": "#/$defs/confidence" }
        },
        "additionalProperties": true
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "purpose", "files", "dependencies", "interfaces", "tests", "proof_gaps", "unknowns", "source_refs"],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "name": { "type": "string", "minLength": 1 },
          "purpose": { "type": "string", "minLength": 1 },
          "files": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "dependencies": { "type": "array", "items": { "$ref": "#/$defs/idOrPath" } },
          "interfaces": { "type": "array", "items": { "$ref": "#/$defs/id" } },
          "tests": { "type": "array", "items": { "$ref": "#/$defs/idOrPath" } },
          "proof_gaps": { "type": "array", "items": { "$ref": "#/$defs/id" } },
          "unknowns": { "type": "array", "items": { "$ref": "#/$defs/idOrPath" } },
          "source_refs": { "$ref": "#/$defs/sourceRefs" },
          "authority_state": { "$ref": "#/$defs/authorityState" },
          "approval_state": { "$ref": "#/$defs/approvalState" },
          "confidence": { "$ref": "#/$defs/confidence" }
        },
        "additionalProperties": true
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "classification", "owner_component_id", "ownership_status", "source_refs", "content_hash", "mapped_at"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "classification": { "type": "string", "minLength": 1 },
          "component_id": { "$ref": "#/$defs/id" },
          "owner_component_id": { "$ref": "#/$defs/id" },
          "ownership_status": { "type": "string", "enum": ["owned", "unknown", "generated", "vendored", "ignored"] },
          "source_refs": { "$ref": "#/$defs/sourceRefs" },
          "content_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "mapped_at": { "type": "string", "minLength": 1 },
          "authority_state": { "$ref": "#/$defs/authorityState" },
          "approval_state": { "$ref": "#/$defs/approvalState" },
          "confidence": { "$ref": "#/$defs/confidence" }
        },
        "additionalProperties": true
      }
    },
    "dependencies": { "type": "array", "items": { "$ref": "#/$defs/sourcedRecord" } },
    "services": {
      "type": "object",
      "required": ["discovered", "negative_evidence", "gaps"],
      "properties": {
        "discovered": { "type": "array", "items": { "$ref": "#/$defs/serviceRecord" } },
        "negative_evidence": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "gaps": { "type": "array", "items": { "$ref": "#/$defs/id" } }
      },
      "additionalProperties": true
    },
    "interfaces": { "type": "array", "items": { "$ref": "#/$defs/sourcedRecord" } },
    "data_stores": { "type": "array", "items": { "$ref": "#/$defs/sourcedRecord" } },
    "tests": { "type": "array", "items": { "$ref": "#/$defs/sourcedRecord" } },
    "unknowns": { "type": "array", "items": { "$ref": "#/$defs/sourcedRecord" } },
    "sources": { "type": "array", "items": { "$ref": "#/$defs/sourceRecord" } }
  },
  "$defs": {
    "semver": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "id": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9._:\\-]*$" },
    "idOrPath": { "type": "string", "minLength": 1 },
    "sourceRefs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/id" } },
    "authorityState": { "type": "string", "enum": ["human_approved", "repo_observed", "externally_sourced", "execution_evidence", "mathematically_proven", "inferred", "unknown"] },
    "approvalState": { "type": "string", "enum": ["approved", "pending", "rejected", "not_required"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "severity": { "type": "string", "enum": ["info", "warning", "blocker"] },
    "sourcedText": {
      "type": "object",
      "required": ["summary", "source_refs"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "source_refs": { "$ref": "#/$defs/sourceRefs" },
        "authority_state": { "$ref": "#/$defs/authorityState" },
        "approval_state": { "$ref": "#/$defs/approvalState" },
        "confidence": { "$ref": "#/$defs/confidence" }
      },
      "additionalProperties": true
    },
    "sourcedRecord": {
      "type": "object",
      "required": ["id", "source_refs"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "source_refs": { "$ref": "#/$defs/sourceRefs" },
        "authority_state": { "$ref": "#/$defs/authorityState" },
        "approval_state": { "$ref": "#/$defs/approvalState" },
        "confidence": { "$ref": "#/$defs/confidence" }
      },
      "additionalProperties": true
    },
    "serviceRecord": {
      "type": "object",
      "required": ["id", "name", "kind", "owner_component", "interfaces", "cost_model", "data_risk", "runtime_dependency", "approval_required_for_changes", "source_refs", "unknowns"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "owner_component": { "$ref": "#/$defs/id" },
        "interfaces": { "type": "array", "items": { "$ref": "#/$defs/id" } },
        "cost_model": { "type": "string", "minLength": 1 },
        "data_risk": { "type": "string", "minLength": 1 },
        "runtime_dependency": { "type": "boolean" },
        "approval_required_for_changes": { "type": "boolean" },
        "source_refs": { "$ref": "#/$defs/sourceRefs" },
        "unknowns": { "type": "array", "items": { "$ref": "#/$defs/idOrPath" } },
        "authority_state": { "$ref": "#/$defs/authorityState" },
        "approval_state": { "$ref": "#/$defs/approvalState" },
        "confidence": { "$ref": "#/$defs/confidence" }
      },
      "additionalProperties": true
    },
    "sourceRecord": {
      "type": "object",
      "required": ["id", "kind", "authority_state", "approval_state", "confidence"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": { "type": "string", "enum": ["human_input", "repo_observation", "command_execution", "external_source_snapshot", "mathematical_or_code_proof", "inference", "unknown"] },
        "description": { "type": "string" },
        "authority_state": { "$ref": "#/$defs/authorityState" },
        "approval_state": { "$ref": "#/$defs/approvalState" },
        "confidence": { "$ref": "#/$defs/confidence" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
