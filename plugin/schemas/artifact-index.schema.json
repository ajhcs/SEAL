{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seal.local/schemas/artifact-index.schema.json",
  "title": "SEAL Artifact Index",
  "type": "object",
  "required": ["schema_version", "generated_from", "notice", "freshness", "stats", "records", "relations"],
  "properties": {
    "schema_version": { "$ref": "#/$defs/semver" },
    "generated_from": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "notice": { "type": "string", "minLength": 1 },
    "freshness": {
      "type": "object",
      "required": ["status", "generated_at"],
      "properties": {
        "status": { "type": "string", "enum": ["current", "stale", "unknown"] },
        "generated_at": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "stats": {
      "type": "object",
      "required": ["record_count", "relation_count", "byte_count"],
      "properties": {
        "record_count": { "type": "integer", "minimum": 0 },
        "relation_count": { "type": "integer", "minimum": 0 },
        "byte_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "records": {
      "type": "array",
      "items": { "$ref": "#/$defs/indexRecord" }
    },
    "relations": {
      "type": "array",
      "items": { "$ref": "#/$defs/indexRelation" }
    }
  },
  "$defs": {
    "semver": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "sourceRefs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "indexRecord": {
      "type": "object",
      "required": ["key", "id", "kind", "artifact_type", "artifact_path", "json_pointer", "summary", "source_refs", "hash", "byte_count", "freshness"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "artifact_type": { "type": "string", "minLength": 1 },
        "artifact_path": { "type": "string", "minLength": 1 },
        "json_pointer": { "type": "string", "pattern": "^/" },
        "summary": { "type": "string", "maxLength": 280 },
        "source_refs": { "$ref": "#/$defs/sourceRefs" },
        "hash": { "$ref": "#/$defs/sha256" },
        "byte_count": { "type": "integer", "minimum": 0 },
        "freshness": {
          "type": "object",
          "required": ["status", "hash"],
          "properties": {
            "status": { "type": "string", "enum": ["current", "stale", "unknown"] },
            "hash": { "$ref": "#/$defs/sha256" }
          },
          "additionalProperties": true
        },
        "path": { "type": "string", "minLength": 1 },
        "impact_targets": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "relation_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      },
      "additionalProperties": false
    },
    "indexRelation": {
      "type": "object",
      "required": ["id", "type", "from", "to", "artifact_type", "artifact_path", "json_pointer", "source_refs"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "artifact_type": { "type": "string", "minLength": 1 },
        "artifact_path": { "type": "string", "minLength": 1 },
        "json_pointer": { "type": "string", "pattern": "^/" },
        "source_refs": { "$ref": "#/$defs/sourceRefs" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
